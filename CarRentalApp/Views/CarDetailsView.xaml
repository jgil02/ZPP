<Window x:Class="CarRentalApp.Views.CarDetailsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Specyfikacja Pojazdu" Height="500" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#F1F2F6">

    <Border Background="White" Margin="20" CornerRadius="10" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="{Binding SelectedCar.FullName}" FontSize="24" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <Image Source="{Binding SelectedCar.ImagePath}" Height="120" Stretch="Uniform" Margin="0,0,0,20"/>

            <TextBlock Text="Specyfikacja techniczna:" FontWeight="Bold" Foreground="#7F8C8D" Margin="0,0,0,10"/>

            <Grid Margin="10,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <!-- Rząd 0 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Segment:" Foreground="#95A5A6"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedCar.Segment}" FontWeight="SemiBold" Foreground="#2C3E50"/>

                <!-- Rząd 1 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Nadwozie:" Foreground="#95A5A6"/>
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedCar.BodyType}" FontWeight="SemiBold" Foreground="#2C3E50"/>

                <!-- Rząd 2 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Ilość miejsc:" Foreground="#95A5A6"/>
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedCar.SeatsCount}" FontWeight="SemiBold" Foreground="#2C3E50"/>

                <!-- Rząd 3 -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="Ilość drzwi:" Foreground="#95A5A6"/>
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedCar.DoorsCount}" FontWeight="SemiBold" Foreground="#2C3E50"/>

                <!-- Rząd 4 -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Pojemność silnika:" Foreground="#95A5A6"/>
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding SelectedCar.EngineCapacity, StringFormat={}{0:F1} L}" FontWeight="SemiBold" Foreground="#2C3E50"/>

                <!-- Rząd 5 -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="Bagażnik:" Foreground="#95A5A6"/>
                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedCar.TrunkCapacity, StringFormat={}{0} litrów}" FontWeight="SemiBold" Foreground="#2C3E50"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>