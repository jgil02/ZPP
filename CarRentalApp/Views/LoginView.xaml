<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="CarRentalApp.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CarRentalApp.ViewModels"
        Title="System Wypożyczalni - Logowanie" 
        Height="650" Width="550"
        WindowStartupLocation="CenterScreen" 
        Background="#2F3542" 
        ResizeMode="NoResize" 
        WindowStyle="ThreeDBorderWindow">

	<Window.DataContext>
		<vm:LoginViewModel />
	</Window.DataContext>

	<Grid>
		
		<Border>
			<Border.Background>
				<LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
					<GradientStop Color="#2C3E50" Offset="0"/>
					<GradientStop Color="#000000" Offset="1"/>
				</LinearGradientBrush>
			</Border.Background>
		</Border>

		
		<Border VerticalAlignment="Center" HorizontalAlignment="Center" 
                Width="420" Padding="45" Background="White" CornerRadius="20">
			<Border.Effect>
				<DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.4" ShadowDepth="0"/>
			</Border.Effect>

			<StackPanel>
				
				<TextBlock FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,15"/>

				<TextBlock Text="Panel logowania" FontSize="28" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="#2C3E50"/>
				<TextBlock Text="Zaloguj się" FontSize="14" Foreground="#7F8C8D" 
                           HorizontalAlignment="Center" Margin="0,5,0,35"/>

				
				<TextBlock Text="NAZWA UŻYTKOWNIKA" FontSize="11" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8"/>
				<Border BorderBrush="#D1D8E0" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,20">
					<TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             BorderThickness="0" Padding="12,10" Height="45" FontSize="15"
                             VerticalContentAlignment="Center" Background="Transparent"/>
				</Border>

				
				<TextBlock Text="HASŁO" FontSize="11" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8"/>
				<Border BorderBrush="#D1D8E0" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,10">
					<TextBox Text="{Binding Password, UpdateSourceTrigger=PropertyChanged}" 
                             BorderThickness="0" Padding="12,10" Height="45" FontSize="15"
                             VerticalContentAlignment="Center" Background="Transparent"/>
				</Border>

				
				<TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="12" 
                           HorizontalAlignment="Center" Margin="0,10" Height="20" FontWeight="SemiBold"/>

				
				<Button Command="{Binding LoginCommand}" Content="ZALOGUJ" 
                        Height="50" Margin="0,10,0,0" Cursor="Hand" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0">
					<Button.Style>
						<Style TargetType="Button">
							<Setter Property="Background" Value="#2980B9"/>
							<Setter Property="Template">
								<Setter.Value>
									<ControlTemplate TargetType="Button">
										<Border Background="{TemplateBinding Background}" CornerRadius="10">
											<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
										</Border>
									</ControlTemplate>
								</Setter.Value>
							</Setter>
							<Style.Triggers>
								<Trigger Property="IsMouseOver" Value="True">
									<Setter Property="Background" Value="#3498DB"/>
								</Trigger>
								<Trigger Property="IsPressed" Value="True">
									<Setter Property="Background" Value="#2471A3"/>
								</Trigger>
							</Style.Triggers>
						</Style>
					</Button.Style>
				</Button>

				
				<StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,0">
					<TextBlock Text="Wypożyczalnia AutoExpert" FontSize="11" Foreground="#BDC3C7"/>
				</StackPanel>
			</StackPanel>
		</Border>
	</Grid>
</Window>