<Window x:Class="CarRentalApp.Views.ReservationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kreator Rezerwacji" Height="400" Width="350"
        WindowStartupLocation="CenterScreen"
        x:Name="ResWindow"
        Background="#F1F2F6">

    <Border Background="White" Margin="20" CornerRadius="10" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" Opacity="0.1" ShadowDepth="2"/>
        </Border.Effect>

        <StackPanel>
            <TextBlock Text="Zarezerwuj pojazd" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,20" HorizontalAlignment="Center"/>

            <TextBlock Text="Data odbioru:" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>

            <DatePicker SelectedDate="{Binding StartDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" FontSize="14"/>

            <TextBlock Text="Data zwrotu:" FontWeight="SemiBold" Foreground="#7F8C8D" Margin="0,0,0,5"/>
            <DatePicker SelectedDate="{Binding EndDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,25" FontSize="14"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <TextBlock Text="Całkowity koszt: " FontSize="16" Foreground="#2C3E50" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalPrice}" FontSize="22" FontWeight="Bold" Foreground="#27AE60"/>
                <TextBlock Text=" zł" FontSize="22" FontWeight="Bold" Foreground="#27AE60"/>
            </StackPanel>


            <Button Content="POTWIERDŹ REZERWACJĘ" 
                    Command="{Binding ConfirmReservationCommand}"
                    CommandParameter="{Binding ElementName=ResWindow}"
                    Height="45" Background="#34495E" Foreground="White" FontSize="14" FontWeight="Bold" BorderThickness="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>
    </Border>
</Window>