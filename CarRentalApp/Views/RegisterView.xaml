<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="CarRentalApp.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CarRentalApp.ViewModels"
        Title="Wypożyczalnia AutoExpert - Rejestracja" 
        Height="700" Width="550"
        WindowStartupLocation="CenterScreen" 
        Background="#2F3542" 
        ResizeMode="NoResize" 
        WindowStyle="ThreeDBorderWindow">

    <Window.DataContext>
        <vm:RegisterViewModel />
    </Window.DataContext>

    <Grid>
        <Border>
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#2C3E50" Offset="0"/>
                    <GradientStop Color="#000000" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        
        <Border VerticalAlignment="Center" HorizontalAlignment="Center" 
                Width="420" Padding="40" Background="White" CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.4" ShadowDepth="0"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock FontSize="50" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Text="Nowe Konto" FontSize="28" FontWeight="Bold" 
                           HorizontalAlignment="Center" Foreground="#2C3E50"/>
                <TextBlock Text="Dołącz do systemu AutoExpert" FontSize="14" Foreground="#7F8C8D" 
                           HorizontalAlignment="Center" Margin="0,5,0,30"/>

                
                <TextBlock Text="NAZWA UŻYTKOWNIKA" FontSize="11" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8"/>
                <Border BorderBrush="#D1D8E0" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,15">
                    <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" 
                             BorderThickness="0" Padding="12,10" Height="40" FontSize="14"
                             VerticalContentAlignment="Center" Background="Transparent"/>
                </Border>

                
                <TextBlock Text="HASŁO" FontSize="11" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8"/>
                <Border BorderBrush="#D1D8E0" BorderThickness="1.5" CornerRadius="8" Margin="0,0,0,20">
                    <PasswordBox x:Name="RegPasswordBox" 
                                 BorderThickness="0" Padding="12,10" Height="40" FontSize="14"
                                 VerticalContentAlignment="Center" Background="Transparent"/>
                </Border>

                
                <TextBlock Text="TYP KONTA" FontSize="11" FontWeight="Bold" Foreground="#34495E" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <RadioButton Content="Klient" IsChecked="True" Foreground="#34495E" Margin="10,0" FontWeight="SemiBold" Cursor="Hand"/>
                    <RadioButton Content="Pracownik" IsChecked="{Binding IsRegisteringAsWorker}" Foreground="#34495E" Margin="10,0" FontWeight="SemiBold" Cursor="Hand"/>
                </StackPanel>

                
                <Button Command="{Binding RegisterCommand}" 
                        CommandParameter="{Binding ElementName=RegPasswordBox}"
                        Content="UTWÓRZ KONTO" 
                        Height="50" Cursor="Hand" Foreground="White" FontSize="16" FontWeight="Bold" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2980B9"/>
                            
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3498DB"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                
                <Button Content="Masz już konto? Zaloguj się" 
                        Background="Transparent" BorderThickness="0" Foreground="#2980B9"
                        Margin="0,20,0,0" Cursor="Hand" FontWeight="SemiBold" FontSize="12"
                        Click="BackToLogin_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>